#!/usr/bin/env bash
# Installs Nginx and configures a custom 404 page returning 'Ceci n'est pas une page'

apt-get update -y
apt-get install -y nginx

echo "Holberton School" > /var/www/html/index.html
echo "Ceci n'est pas une page" > /usr/share/nginx/html/404.html

# Inject custom 404 page configuration
sed -i '/server_name _;/a \    error_page 404 /404.html;\n    location = /404.html {\n        root /usr/share/nginx/html;\n        internal;\n    }' /etc/nginx/sites-available/default

service nginx restart
